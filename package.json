{
  "name": "@revisium/payment-client",
  "version": "0.1.0",
  "description": "Generated TypeScript client for revisium-payment service",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "generate:download": "curl -o specs/openapi.json http://localhost:8082/api-json && npm run generate",
    "build": "tsdown && npm run build:dts",
    "build:dts": "tsc -p tsconfig.build.json",
    "tsc": "tsc --noEmit",
    "lint:ci": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest --maxWorkers=50% --forceExit",
    "test:cov": "node --experimental-vm-modules ./node_modules/.bin/jest --maxWorkers=50% --forceExit --coverage --silent",
    "format": "prettier --write \"src/**/*.ts\"",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@hey-api/client-fetch": "^0.13.0",
    "@hey-api/openapi-ts": "^0.92.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^3.0.2",
    "globals": "^16.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.0"
  },
  "jest": {
    "extensionsToTreatAsEsm": [".ts"],
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/generated/**",
      "!src/**/__tests__/**",
      "!src/**/index.ts"
    ],
    "coverageReporters": ["text-summary", "lcov"]
  }
}
