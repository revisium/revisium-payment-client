{
  "name": "@revisium/payment-client",
  "version": "0.1.0",
  "description": "Generated TypeScript client for revisium-payment service",
  "keywords": [
    "revisium",
    "payment",
    "client",
    "rest-api",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revisium/revisium-payment-client.git"
  },
  "license": "MIT",
  "author": "Anton Kashirov",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && npm run build:dts",
    "build:dts": "tsc -p tsconfig.build.json",
    "dev": "tsdown --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --silent --passWithNoTests",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "lint:ci": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "tsc": "tsc --noEmit",
    "generate": "openapi-ts",
    "generate:download": "curl -o specs/openapi.json http://localhost:8082/api-json && npm run generate",
    "prepublishOnly": "npm run build && npm run tsc"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@hey-api/openapi-ts": "^0.92.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^3.0.2",
    "globals": "^16.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/generated/**",
      "!src/**/__tests__/**",
      "!src/**/index.ts"
    ],
    "coverageReporters": [
      "text-summary",
      "lcov"
    ]
  }
}
