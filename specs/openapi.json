{
  "openapi": "3.0.0",
  "paths": {
    "/checkout": {
      "post": {
        "operationId": "PaymentController_createCheckout",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCheckoutDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutResponseModel"
                }
              }
            }
          },
          "400": {
            "description": "No available provider",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Invalid HMAC signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Create checkout session",
        "tags": [
          "Payment"
        ]
      }
    },
    "/providers": {
      "get": {
        "operationId": "PaymentController_getProviders",
        "parameters": [
          {
            "name": "country",
            "required": false,
            "in": "query",
            "description": "Country code (e.g. US, DE)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "method",
            "required": false,
            "in": "query",
            "description": "Payment method (e.g. card, crypto)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvidersResponseModel"
                }
              }
            }
          },
          "401": {
            "description": "Invalid HMAC signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Get available payment providers",
        "tags": [
          "Payment"
        ]
      }
    },
    "/cancel": {
      "post": {
        "operationId": "PaymentController_cancelSubscription",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelSubscriptionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription cancelled"
          },
          "401": {
            "description": "Invalid HMAC signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "404": {
            "description": "No active subscription found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Cancel subscription",
        "tags": [
          "Payment"
        ]
      }
    },
    "/portal": {
      "get": {
        "operationId": "PaymentController_getPortal",
        "parameters": [
          {
            "name": "organizationId",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "returnUrl",
            "required": true,
            "in": "query",
            "description": "URL to return to after portal",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PortalResponseModel"
                }
              }
            }
          },
          "401": {
            "description": "Invalid HMAC signature",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Get customer portal URL",
        "tags": [
          "Payment"
        ]
      }
    },
    "/webhooks/{providerId}": {
      "post": {
        "operationId": "WebhookController_handleWebhook",
        "parameters": [
          {
            "name": "providerId",
            "required": true,
            "in": "path",
            "description": "Payment provider ID (e.g. stripe, cloudpayments)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook processed (response format varies by provider)"
          },
          "404": {
            "description": "Unknown provider",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Receive provider webhook",
        "tags": [
          "Webhooks"
        ]
      }
    },
    "/api/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sets httpOnly cookies with access and refresh tokens"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Login with email and password",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Tokens refreshed"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Refresh access token using refresh token cookie",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "204": {
            "description": "Logged out"
          }
        },
        "summary": "Logout and clear auth cookies",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/sign-up": {
      "post": {
        "operationId": "AuthController_signUp",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current user data"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Get current user info",
        "tags": [
          "Auth"
        ]
      }
    }
  },
  "info": {
    "title": "Revisium Payment Service",
    "description": "Multi-provider payment orchestration service",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "Payment",
      "description": "Payment orchestration (HMAC-authenticated)"
    },
    {
      "name": "Webhooks",
      "description": "Provider webhook endpoints"
    },
    {
      "name": "Admin",
      "description": "Payment administration"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateCheckoutDto": {
        "type": "object",
        "properties": {
          "organizationId": {
            "type": "string"
          },
          "planId": {
            "type": "string"
          },
          "interval": {
            "type": "string",
            "enum": [
              "monthly",
              "yearly"
            ]
          },
          "providerId": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "method": {
            "type": "string",
            "description": "Payment method (e.g. card, crypto, bank_transfer)"
          },
          "customerEmail": {
            "type": "string"
          },
          "successUrl": {
            "type": "string"
          },
          "cancelUrl": {
            "type": "string"
          }
        },
        "required": [
          "organizationId",
          "planId",
          "successUrl",
          "cancelUrl"
        ]
      },
      "CheckoutResponseModel": {
        "type": "object",
        "properties": {
          "checkoutUrl": {
            "type": "string",
            "description": "URL to redirect user to complete payment"
          },
          "intentId": {
            "type": "string",
            "description": "Payment intent ID"
          },
          "providerId": {
            "type": "string",
            "description": "Selected payment provider ID"
          }
        },
        "required": [
          "checkoutUrl",
          "intentId",
          "providerId"
        ]
      },
      "ErrorModel": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number"
          },
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "statusCode",
          "message"
        ]
      },
      "ProviderModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Provider ID (e.g. stripe, cloudpayments)"
          },
          "name": {
            "type": "string",
            "description": "Provider display name"
          },
          "methods": {
            "description": "Supported payment methods",
            "example": [
              "card",
              "crypto"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "supportsRecurring": {
            "type": "boolean",
            "description": "Whether provider supports recurring subscriptions"
          }
        },
        "required": [
          "id",
          "name",
          "methods",
          "supportsRecurring"
        ]
      },
      "ProvidersResponseModel": {
        "type": "object",
        "properties": {
          "providers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProviderModel"
            }
          }
        },
        "required": [
          "providers"
        ]
      },
      "CancelSubscriptionDto": {
        "type": "object",
        "properties": {
          "organizationId": {
            "type": "string"
          },
          "cancelAtPeriodEnd": {
            "type": "boolean",
            "default": true
          }
        },
        "required": [
          "organizationId"
        ]
      },
      "PortalResponseModel": {
        "type": "object",
        "properties": {
          "url": {
            "type": "object",
            "description": "Portal URL (null if not supported)",
            "nullable": true
          },
          "supported": {
            "type": "boolean",
            "description": "Whether the provider supports customer portal"
          }
        },
        "required": [
          "url",
          "supported"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email"
          },
          "password": {
            "type": "string",
            "description": "User password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SignUpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "User email"
          },
          "username": {
            "type": "string",
            "description": "Username"
          },
          "password": {
            "type": "string",
            "description": "User password",
            "minLength": 6
          }
        },
        "required": [
          "email",
          "username",
          "password"
        ]
      }
    }
  }
}
